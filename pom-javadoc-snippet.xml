<!--
  ADD THIS INSIDE the existing <reporting><plugins> block in pom.xml.
  Place it alongside the other report plugins (checkstyle, pmd, jacoco, etc.)
-->

<!-- Javadoc report — generates site/apidocs/ during mvn site -->
<plugin>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-javadoc-plugin</artifactId>
  <version>3.6.3</version>
  <reportSets>
    <reportSet>
      <reports>
        <report>javadoc</report>
      </reports>
    </reportSet>
  </reportSets>
  <configuration>
    <!-- Suppress strict doclint errors that would break the site build -->
    <doclint>none</doclint>
  </configuration>
</plugin>
